# 应用环境
# 当前仓库的 dev server / smoke 脚本会自动加载当前工作区下的 .env 和 .env.local
# compose.yaml 也会读取当前仓库根目录下的 .env
NODE_ENV=development

# MySQL 是核心真相源
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=agent_ide
MYSQL_USER=root
MYSQL_PASSWORD=change-me
MYSQL_POOL_MIN=0
MYSQL_POOL_MAX=10

# Redis 负责热缓存、session lease 和后续队列能力
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0
SESSION_SUMMARY_TTL_SECONDS=900
SESSION_LEASE_TTL_MS=30000

# MiniMax 文本模型接入
# 国际站可用 https://api.minimax.io/v1
# 国内环境可改成 https://api.minimaxi.com/v1
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-M2.7
MINIMAX_TEMPERATURE=0.2
MINIMAX_TIMEOUT_MS=60000
