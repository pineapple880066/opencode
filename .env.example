# 应用环境
NODE_ENV=development

# MySQL 是核心真相源
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=agent_ide
MYSQL_USER=root
MYSQL_PASSWORD=change-me
MYSQL_POOL_MIN=0
MYSQL_POOL_MAX=10

# Redis 负责热缓存、session lease 和后续队列能力
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0
SESSION_SUMMARY_TTL_SECONDS=900
SESSION_LEASE_TTL_MS=30000

